From 1472d4153633eb1328099b0b0b199b9c9d3ce266 Mon Sep 17 00:00:00 2001
From: zerowrt-bot <zj18139624826@gmail.com>
Date: Fri, 24 Apr 2026 07:51:22 +0800
Subject: [PATCH] target: mediatek: add LED netdev support for clx,s20p

Add LED configuration for clx,s20p board:
- Configure 2.4GHz WLAN LED (ra0)
- Configure 5GHz WLAN LED (rax0)
- Use blue:wlan-2ghz and blue:wlan-5ghz triggers

This ensures proper WiFi activity indication via LEDs.
---
 target/linux/mediatek/filogic/base-files/etc/board.d/01_leds | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/target/linux/mediatek/filogic/base-files/etc/board.d/01_leds b/target/linux/mediatek/filogic/base-files/etc/board.d/01_leds
index 18de8cd721..74b961e609 100644
--- a/target/linux/mediatek/filogic/base-files/etc/board.d/01_leds
+++ b/target/linux/mediatek/filogic/base-files/etc/board.d/01_leds
@@ -42,6 +42,10 @@ bananapi,bpi-r4-poe)
 	ucidef_set_led_netdev "lan2" "lan2" "mt7530-0:02:green:lan" "lan2" "link tx rx"
 	ucidef_set_led_netdev "lan3" "lan3" "mt7530-0:03:green:lan" "lan3" "link tx rx"
 	;;
+clx,s20p)
+	ucidef_set_led_netdev "wlan2g" "WLAN2G" "blue:wlan-2ghz" "ra0"
+	ucidef_set_led_netdev "wlan5g" "WLAN5G" "blue:wlan-5ghz" "rax0"
+	;;
 confiabits,mt7981)
 	ucidef_set_led_netdev "lan1" "lan1" "blue:lan-1" "lan1" "link tx rx"
 	ucidef_set_led_netdev "lan2" "lan2" "blue:lan-2" "lan2" "link tx rx"
-- 
